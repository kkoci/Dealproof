# Anthropic
ANTHROPIC_API_KEY=

# dstack / TEE
DSTACK_SIMULATOR_ENDPOINT=http://localhost:8090
TEE_MODE=simulation  # simulation | production

# Blockchain (Phase 4)
# RPC_URL: Sepolia endpoint — https://sepolia.infura.io/v3/YOUR_KEY
# PRIVATE_KEY: throwaway dev wallet private key (no mainnet funds)
# CONTRACT_ADDRESS: set after running: cd contracts && npx hardhat run scripts/deploy.js --network sepolia
RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
PRIVATE_KEY=
CONTRACT_ADDRESS=

# Memory sidecar — set ONE of the following provider keys.
# Auto-detected in priority order: openai > gemini > openrouter.
# Override with MEMORY_PROVIDER=gemini (or openai / openrouter) if needed.
MEMORY_SERVICE_URL=http://memory-service:4011
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Arc on-chain credential anchoring (ETHGlobal M6)
# ARC_RPC_URL: Arc network RPC endpoint
# ARC_CHAIN_ID: Arc network chain ID
# ARCID_REGISTRY_ADDRESS: deployed ArcIDRegistry contract address
ARC_RPC_URL=
ARC_CHAIN_ID=0
ARCID_REGISTRY_ADDRESS=

# App
DEBUG=true
LOG_LEVEL=INFO
